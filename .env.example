# Agora local development defaults
# Copy to `.env` and adjust if needed.

AGORA_SERVER_HOST=127.0.0.1
AGORA_BACKEND_PORT=18420
AGORA_FRONTEND_PORT=33173
AGORA_SERVER_URL=http://127.0.0.1:18420
VITE_API_BASE_URL=http://127.0.0.1:18420

# Optional local overrides
AGORA_DB_PATH=$HOME/.agora/agora.db
AGORA_CONFIG_PATH=
AGORA_CLEAN_LEGACY_PORTS=1
AGORA_CRAFTSMAN_SERVER_MODE=watched
AGORA_CRAFTSMAN_CLI_MODE=tmux

# Developer-only: enables operator proxy behavior for live regression harnesses.
# Keep this disabled for normal product usage.
AGORA_DEV_REGRESSION_MODE=false
AGORA_DASHBOARD_LOGIN_USER=
AGORA_DASHBOARD_LOGIN_PASSWORD=

# Optional fallback: project brain hybrid retrieval
# `./agora init` can now collect these values, verify the embedding API,
# and install/reuse local Qdrant automatically.
# Keep this section for manual overrides or non-interactive setup only.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSION=
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
