#!/bin/bash
# ZeYu Docs Retrieval - Bash entry point
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Priority:
# 1) skill-local .venv
# 2) miniforge python (terminal default base candidate)
# 3) system python3
if [[ -x "$SCRIPT_DIR/.venv/bin/python" ]]; then
  PYTHON_BIN="$SCRIPT_DIR/.venv/bin/python"
elif [[ -x "/Users/lizeyu/miniforge/bin/python" ]]; then
  PYTHON_BIN="/Users/lizeyu/miniforge/bin/python"
else
  PYTHON_BIN="python3"
fi

exec "$PYTHON_BIN" "$SCRIPT_DIR/zdr.py" "$@"
