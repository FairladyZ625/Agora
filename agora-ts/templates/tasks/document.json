{
  "name": "文档撰写",
  "type": "document",
  "description": "大纲讨论、撰写和审校的文档工作",
  "defaultWorkflow": "outline-write-review",
  "governance": "standard",
  "defaultTeam": {
    "writer": { "member_kind": "controller", "suggested": ["glm5"] },
    "reviewer": { "member_kind": "citizen", "suggested": ["gpt52"] }
  },
  "stages": [
    { "id": "outline", "name": "大纲讨论", "mode": "discuss", "execution_kind": "citizen_discuss", "gate": { "type": "archon_review" } },
    { "id": "write", "name": "撰写", "mode": "execute", "execution_kind": "citizen_execute", "gate": { "type": "all_subtasks_done" } },
    { "id": "review", "name": "审校", "mode": "discuss", "execution_kind": "citizen_discuss", "gate": { "type": "approval", "approver": "reviewer" }, "reject_target": "write" }
  ]
}
