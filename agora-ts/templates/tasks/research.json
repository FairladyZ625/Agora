{
  "name": "调研任务",
  "type": "research",
  "description": "资料收集、协作分析和报告撰写",
  "defaultWorkflow": "collect-analyze-report",
  "governance": "lean",
  "defaultTeam": {
    "researcher": { "suggested": ["gemini31pro"] },
    "analyst": { "suggested": ["gpt52"] },
    "writer": { "suggested": ["glm5"] }
  },
  "stages": [
    { "id": "collect", "name": "资料收集", "mode": "execute", "gate": { "type": "all_subtasks_done" } },
    { "id": "analyze", "name": "协作分析", "mode": "discuss", "gate": { "type": "archon_review" } },
    { "id": "report", "name": "报告撰写", "mode": "execute", "gate": { "type": "approval", "approver": "analyst" } }
  ]
}
