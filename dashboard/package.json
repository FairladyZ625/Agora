{
  "name": "dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:compat": "node ./scripts/browser-smoke.mjs",
    "test:perf": "node ./scripts/perf-snapshot.mjs",
    "test:browsers:install": "playwright install chromium firefox webkit",
    "build": "tsc -b && vite build",
    "lint": "eslint . && npm run lint:design",
    "lint:design": "node ./scripts/check-visual-governance.mjs",
    "check": "npm test && npm run lint && npx tsc -b && npm run build",
    "check:strict": "npm run check && npm run test:coverage",
    "preview": "vite preview"
  },
  "dependencies": {
    "@agora-ts/contracts": "file:../agora-ts/packages/contracts",
    "@tailwindcss/vite": "^4.2.1",
    "i18next": "^25.8.14",
    "liquid-glass-react": "^1.1.1",
    "lucide-react": "^0.577.0",
    "motion": "^12.35.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.6",
    "react-router": "^7.13.1",
    "tailwindcss": "^4.2.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.8",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.2.0",
    "playwright": "^1.54.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.8"
  }
}
